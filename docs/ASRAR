```bash
# ═══════════════════════════════════════
# ASRAR Shield Configuration File
# ═══════════════════════════════════════

# ─── General Settings ───
MODE=aggressive              # passive|adaptive|aggressive|quantum
AUTO_BLOCK=true             # حظر تلقائي للتهديدات
LOG_LEVEL=verbose           # silent|normal|verbose|debug
SCAN_INTERVAL=60            # ثانية بين كل فحص

# ─── Network Settings ───
NETWORK_MONITOR=true        # تفعيل مراقبة الشبكة
BLOCK_SUSPICIOUS_IPS=true   # حظر IPs المشبوهة
MAX_CONNECTIONS=100         # أقصى عدد اتصالات مسموح

# ─── DNS Settings ───
DNS_FILTER=true             # تفعيل فلتر DNS
PREFERRED_DNS=1.1.1.1       # DNS المفضل
SECONDARY_DNS=8.8.8.8       # DNS احتياطي
BLOCK_DNS_TUNNELING=true    # حظر DNS tunneling

# ─── APK Scanning ───
APK_SCAN=true               # تفعيل فحص APK
AUTO_QUARANTINE=true        # حجر تلقائي للمشبوهات
DEEP_SCAN=false             # فحص عميق (بطيء)
VIRUSTOTAL_API=             # مفتاح VirusTotal API

# ─── AI/ML Settings ───
AI_DETECTION=true           # تفعيل AI
ML_MODEL=isolation_forest   # نموذج ML المستخدم
ANOMALY_THRESHOLD=0.1       # عتبة الكشف عن الشذوذ

# ─── Encryption ───
QUANTUM_MODE=false          # وضع الكم
ENCRYPTION_LEVEL=high       # low|medium|high|quantum
AUTO_ENCRYPT_LOGS=true      # تشفير السجلات تلقائياً

# ─── Alerts & Notifications ───
ENABLE_ALERTS=true          # تفعيل التنبيهات
ALERT_LEVEL=high            # low|medium|high|critical
ALERT_METHOD=termux-notify  # طريقة التنبيه

# ─── Performance ───
MAX_LOG_SIZE=100M           # حجم السجل الأقصى
LOG_RETENTION_DAYS=30       # مدة حفظ السجلات
AUTO_CLEANUP=true           # تنظيف تلقائي

# ─── Advanced ───
ENABLE_HONEYPOT=false       # فخ للمهاجمين
THREAT_INTELLIGENCE=true    # معلومات التهديدات
AUTO_UPDATE_SIGNATURES=true # تحديث توقيعات تلقائي
```

### تعديل الإعدادات

```bash
# من الواجهة
./asrar-shield.sh config

# يدوياً
nano ~/asrar-shield/config.conf

# من سطر الأوامر
./asrar-shield.sh set MODE=quantum
./asrar-shield.sh set LOG_LEVEL=debug
```

